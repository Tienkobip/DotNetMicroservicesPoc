{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Spring": {
    "Application": {
      "Name": "PolicySearchService"
    }
  },
  "Eureka": {
    "Client": {
      "ShouldRegisterWithEureka": true,
      "ServiceUrl": "http://localhost:8761/eureka",
      "ValidateCertificates": false
    },
    "Instance": {
      "AppName": "PolicySearchService",
      "Port": 5065,
      "HostName": "localhost"
    }
  },
  "ConnectionStrings": {
    "ElasticSearchConnection": "http://localhost:9200"
  }
}